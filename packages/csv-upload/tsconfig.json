{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../..",
    "declaration": true,
    "declarationMap": true,
    "types": ["node", "react", "react-dom"], 
    "baseUrl": ".",
    "composite": true,
    "paths": {
      "types": ["../types/src"], 
      "dsl-validator": ["../dsl-validator/src"],
      "@components/*": ["./src/components/*"],
      "@contexts/*": ["./src/contexts/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@utils/*": ["./src/utils/*"],
      "@types/*": ["./src/types/*"],
      "@components/internal/*": ["./src/components/__internal__/*"]
    }
  },
  "include": ["src", "../types/src/types/*", "../types/src/coordsType.ts", "../types/src/cellDataType.ts", "../dsl-validator/src"],
  "references": [
    {"path": "../types"},
    {"path": "../dsl-validator"}
  ]
}
